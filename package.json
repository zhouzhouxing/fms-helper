{
  "name": "fms-helper",
  "version": "2.3.3",
  "description": "FMS Helper - Frame.ManagementSystem 测试脚本配置工具",
  "main": "main.js",
  "scripts": {
    "prebuild": "node scripts/obfuscate.js",
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "postbuild": "node scripts/restore-src.js",
    "prepublish": "node scripts/obfuscate.js",
    "publish": "electron-builder --win nsis --publish always",
    "postpublish": "node scripts/restore-src.js"
  },
  "keywords": [
    "fms",
    "test-script",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.fms-helper.app",
    "productName": "FMS Helper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "FMS-Helper-${version}-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "FMS-Helper-${version}-Setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "zhouzhouxing",
      "repo": "fms-helper"
    }
  },
  "dependencies": {
    "cos-nodejs-sdk-v5": "^2.15.4",
    "electron-updater": "^6.8.9"
  }
}
